{
  "name": "todolist-floating-app",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --port 5173 --strictPort\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "dev:renderer": "vite --port 5173 --strictPort",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron .",
    "server:sync": "node server/index.js",
    "test": "node --test tests/contextMenuLabels.test.ts tests/contextMenuOrder.test.ts tests/contextMenuStyles.test.ts tests/math.test.ts tests/mobileState.test.ts tests/mobileParityState.test.ts tests/mobileStorage.test.ts tests/mobileSyncApi.test.ts tests/nativeAppSource.test.ts tests/syncServerCore.test.ts tests/syncUtils.test.ts tests/taskArchive.test.ts tests/taskCardEditorSource.test.ts tests/taskCardLayout.test.ts tests/taskDurationLayout.test.ts tests/taskMeta.test.ts tests/taskVisibility.test.ts tests/useTaskStore.test.ts electron/runtimePaths.test.cjs electron/syncRuntime.test.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "katex": "^0.16.33",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.neofloat.todo",
    "productName": "Neo Float Todo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icons/neo-float.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Neo Float Todo",
      "installerIcon": "build/icons/neo-float.ico",
      "uninstallerIcon": "build/icons/neo-float.ico",
      "installerHeaderIcon": "build/icons/neo-float.ico"
    }
  }
}
